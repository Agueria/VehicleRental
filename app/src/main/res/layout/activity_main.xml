<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7F9"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vehicle Rental"
            android:textColor="#1F2933"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Lab Task 4 - XML backed rental menu"
            android:textColor="#52606D"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#E8F0FE"
            android:padding="12dp"
            android:textColor="#174EA6"
            android:textSize="15sp"
            tools:text="Loaded initial XML database." />

        <TextView
            android:id="@+id/inventoryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:textColor="#1F2933"
            android:textSize="13sp"
            tools:text="[1] Car - Honda Civic | fuel mask: 3 | fuel: 8.0 L | parked: no" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Add Vehicle"
            android:textColor="#1F2933"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/typeSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Vehicle name"
            android:inputType="textCapWords"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/fuelMaskInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Fuel mask"
                android:inputType="number"
                android:singleLine="true" />

            <EditText
                android:id="@+id/fuelAmountInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Fuel liters"
                android:inputType="numberDecimal"
                android:singleLine="true" />
        </LinearLayout>

        <Button
            android:id="@+id/addVehicleButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#1565C0"
            android:text="Add Vehicle"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Park / Unpark"
            android:textColor="#1F2933"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/parkVehicleIdInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Vehicle ID"
                android:inputType="number"
                android:singleLine="true" />

            <EditText
                android:id="@+id/garageNumberInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Garage #"
                android:inputType="number"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/parkButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#2E7D32"
                android:text="Park"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/unparkButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:backgroundTint="#455A64"
                android:text="Unpark"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Remove Vehicle"
            android:textColor="#1F2933"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/removeVehicleIdInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Vehicle ID"
            android:inputType="number"
            android:singleLine="true" />

        <Button
            android:id="@+id/removeButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#C62828"
            android:text="Remove"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/sortButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#6A1B9A"
                android:text="Sort"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:backgroundTint="#1565C0"
                android:text="Save XML"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/fuelHelpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Fuel mask: 1 Diesel, 2 Petrol, 4 LPG, 8 CNG. Combine with bitwise OR, e.g. 3 = Diesel + Petrol."
            android:textColor="#52606D"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
